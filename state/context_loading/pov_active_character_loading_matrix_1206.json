{
  "id": "pov_active_character_loading_matrix_1206",
  "version": "v1",
  "purpose": "Матрица: кого грузить при разных POV и составах сцены.",
  "rules": [
    {
      "case": "POV Akira, Akira alone/private room",
      "load": [
        "akira main/character digest",
        "akira character_memory",
        "current location private slice",
        "calendar current",
        "scene_output rules",
        "state_write rules"
      ],
      "do_not_load": [
        "raiden",
        "ray",
        "miki",
        "all akira relationship pairs",
        "full NPC rules"
      ],
      "npc_context": "none or light only if triggered"
    },
    {
      "case": "POV Akira with Raiden present",
      "load": [
        "akira",
        "raiden",
        "akira__raiden relationship_pair",
        "relevant protected_moments",
        "location/current calendar"
      ],
      "do_not_load": [
        "all akira__* pairs",
        "haru unless present/mentioned/relevant",
        "hidden bond as spoken truth"
      ]
    },
    {
      "case": "POV Haru alone, Akira absent",
      "load": [
        "haru main/character digest",
        "haru character_memory",
        "location/current calendar",
        "NPC rules by location if open",
        "scene_output rules"
      ],
      "do_not_load": [
        "akira",
        "akira__haru",
        "raiden unless present/mentioned/relevant"
      ]
    },
    {
      "case": "POV Haru + Raiden, Akira absent",
      "load": [
        "haru",
        "raiden",
        "raiden__haru relationship_pair",
        "their active open_threads",
        "location/current calendar"
      ],
      "do_not_load": [
        "akira",
        "akira__raiden",
        "akira__haru"
      ]
    },
    {
      "case": "POV Haru talking to/observing Akira",
      "load": [
        "haru",
        "akira",
        "akira__haru relationship_pair",
        "current scene facts"
      ],
      "do_not_load": [
        "raiden unless present/mentioned/relevant",
        "all akira pairs"
      ]
    },
    {
      "case": "POV Ray closed office conversation with Akira",
      "load": [
        "ray",
        "akira",
        "akira__ray relationship_pair",
        "closed office privacy rules",
        "current calendar",
        "state_write rules"
      ],
      "do_not_load": [
        "public NPC rules full",
        "characters not in room",
        "future calendar hooks"
      ]
    },
    {
      "case": "POV any character in public cafeteria",
      "load": [
        "POV",
        "active speakers",
        "present important characters",
        "relationship pairs only for active interactions",
        "NPC presence full or medium",
        "public location slice"
      ],
      "do_not_load": [
        "private thoughts of non-POV",
        "all relationship pairs",
        "hidden lore"
      ]
    }
  ],
  "character_context_depth": {
    "pov": "medium: personality voice, body/state, memory, known/unknown, current goal",
    "active_speaker": "medium: personality voice, memory relevant to scene, current goal",
    "present_observer": "light: visible behavior, what they can hear/see, relevant memory only",
    "nearby_not_engaged": "very_light or none",
    "mentioned_absent": "relationship/open_thread digest only if needed; no full card by default"
  },
  "source_of_knowledge_required": [
    "Для каждого важного знания NPC должен существовать источник: видел, слышал, документ, приказ, разговор, state, карточка знаний.",
    "Если источника нет — персонаж может только подозревать или ошибаться."
  ]
}