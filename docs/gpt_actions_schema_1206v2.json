{
  "openapi": "3.1.0",
  "info": {
    "title": "Akira 1206 v2 Actions",
    "version": "0.3.136-openapi-context-anchor-cleanup-v1"
  },
  "servers": [
    {
      "url": "https://1206v2-production.up.railway.app"
    }
  ],
  "components": {
    "schemas": {
      "HealthResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
