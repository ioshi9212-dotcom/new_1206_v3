          "version": {
            "type": "string"
          },
          "public_base_url": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "SessionResponse": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "created_at": {
            "type": "string"
          },
          "updated_at": {
            "type": "string"
          },
          "start_scene": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true,
        "required": [
          "session_id"
        ]
      },
      "SizeGuardContextResponse": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "current_state": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "active_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nearby_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "usage_note": {
            "type": "string"
          }
        },
        "additionalProperties": true,
        "required": [
          "session_id"
        ]
      },
      "TurnContractWithPromptPreview": {
        "type": "object",
        "properties": {
          "session_id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "active_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "nearby_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "fast_context_file_hints": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "context_files_available": {
            "type": "integer"
          },
          "output_format_contract": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "required_checks_before_answer": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "knowledge_table": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "inventory_contract": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "relationship_context": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "story_context": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "prompt_preview": {
            "type": "string"
          },
          "fast_context_available": {
            "type": "boolean"
          },
          "preferred_next_action": {
            "type": "string"
          },
          "usage_note": {
            "type": "string"
          }
        },
        "additionalProperties": true,
        "required": [
          "session_id",
          "prompt_preview"
        ]
      },
      "FastRenderContextResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "session_id": {
            "type": "string"
          },
          "mode": {
            "type": "string"
          },
          "quality_mode": {
            "type": "string"
          },
          "context_files_total": {
            "type": "integer"
          },
          "loaded_files": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {},
              "additionalProperties": true
            }
          },
          "loaded_count": {
            "type": "integer"
          },
          "skipped_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "skipped_count": {
            "type": "integer"
          },
          "truncated": {
            "type": "boolean"
          },
          "needs_full_context": {
            "type": "boolean"
          },
          "past_context_loaded": {
            "type": "boolean"
          },
          "render_rules": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      },
      "ProcessTurnResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          },
          "session_id": {
            "type": "string"
          },
          "player_input": {
            "type": "string"
          },
          "current_scene_id": {
            "type": "string"
          },
          "status": {
            "type": "string"
          },
          "scene_text": {
            "type": "string"
          },
          "scene_packet": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "ApplyTurnResultResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "visible_scene_text": {
            "type": "string"
          },
          "final_scene_text": {
            "type": "string"
          }
        },
        "additionalProperties": true
      },
      "PhysicalContinuityRepairResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "physical_continuity_state": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          }
        },
        "additionalProperties": true
      },
      "CharacterEntryRepairResponse": {
        "type": "object",
        "properties": {
          "status": {
            "type": "string"
          },
          "session_id": {
            "type": "string"
          },
          "changed_files": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "reason": {
            "type": "string"
          },
          "pending": {
            "type": "object",
            "properties": {},
            "additionalProperties": true
          },
          "current_state_pending_character_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "paths": {
    "/health": {
      "get": {
        "operationId": "health",
        "summary": "Check API health and runtime version",
        "responses": {
          "200": {
            "description": "API health status",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HealthResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions": {
      "post": {
        "operationId": "createSession",
        "summary": "Create a new gameplay session",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "session_id": {
                    "type": "string"
                  },
                  "title": {
                    "type": "string"
                  },
                  "reset": {
                    "type": "boolean"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Created session",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SessionResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/context": {
      "get": {
        "operationId": "getSessionContext",
        "summary": "Get compact session context",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Compact session context",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/SizeGuardContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/turn-contract": {
      "get": {
        "operationId": "getSessionTurnContract",
        "summary": "Get compact turn contract. For normal turns, call getFastRenderContext next.",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Turn contract",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/TurnContractWithPromptPreview"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/fast-render-context": {
      "get": {
        "operationId": "getFastRenderContext",
        "summary": "Get fast render context for normal gameplay: runtime digest, active character files, and selected state slices",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "max_total_chars",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 24000,
              "minimum": 12000,
              "maximum": 36000
            }
          },
          {
            "name": "per_file_chars",
            "in": "query",
            "required": false,
            "schema": {
              "type": "integer",
              "default": 4000,
              "minimum": 1800,
              "maximum": 7000
            }
          },
          {
            "name": "include_past",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "nullable": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Fast render context",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/FastRenderContextResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/scene-packet": {
      "get": {
        "operationId": "getScenePacket",
        "summary": "Get one compact scene packet",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Scene packet",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {},
                  "additionalProperties": true
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/turn": {
      "post": {
        "operationId": "processTurn",
        "summary": "Return gameplay scene or compact scene packet",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "player_input": {
                    "type": "string"
                  },
                  "mode": {
                    "type": "string",
                    "default": "play"
                  },
                  "include_file_contents": {
                    "type": "boolean",
                    "default": false
                  },
                  "state_patches": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true
                  }
                },
                "additionalProperties": true,
                "required": [
                  "player_input"
                ]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Processed turn",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProcessTurnResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/apply-turn-result": {
      "post": {
        "operationId": "applyTurnResult",
        "summary": "Apply meaningful scene changes and fallback physical continuity from visible_scene_text",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "turn_file": {
                    "type": "string"
                  },
                  "data": {
                    "type": "object",
                    "properties": {},
                    "additionalProperties": true
                  },
                  "dry_run": {
                    "type": "boolean",
                    "default": false
                  },
                  "visible_scene_text": {
                    "type": "string"
                  }
                },
                "additionalProperties": true
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Apply result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApplyTurnResultResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/repair/physical-continuity": {
      "post": {
        "operationId": "repairPhysicalContinuity",
        "summary": "Repair current_state/inventory_state from latest scene_history visible scene",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "dry_run",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Physical continuity repair result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/PhysicalContinuityRepairResponse"
                }
              }
            }
          }
        }
      }
    },
    "/api/v1/sessions/{session_id}/repair/character-entry": {
      "post": {
        "operationId": "repairCharacterEntry",
        "summary": "Repair hidden pending character-entry state, especially Raiden's late-night conditional entry",
        "parameters": [
          {
            "name": "session_id",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "force",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "dry_run",
            "in": "query",
            "required": false,
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Character entry repair result",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/CharacterEntryRepairResponse"
                }
              }
            }
          }
        }
      }
    }
  }
}